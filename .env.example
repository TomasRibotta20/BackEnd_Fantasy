#Base de Datos
DB_HOST=localhost # Host del servidor MySQL.
DB_PORT=3307 # Puerto de MySQL (ajustar si es 3306).
DB_USER=dws # Usuario con permisos.
DB_PASSWORD=dsw #	Contraseña del usuario.
DB_NAME=fantasydatabase # Nombre de la base de datos a conectar.

#JWT
SECRET_JWT_KEY=CLAVE_SECRETA_ACCESS_TOKEN_AQUI # Para tokens de acceso.
SECRET_RESETJWT_KEY=CLAVE_SECRETA_RESET_TOKEN_AQUI # Para tokens de reseteo de contraseña.
SECRET_REFRESHJWT_KEY=CLAVE_SECRETA_REFRESH_TOKEN_AQUI # Para tokens de refresco

#Correo
GMAIL_USER=tu_usuario_de_gmail # (No es obligatorio completar este campo). Esto tiene que ser tu dirección de correo de Gmail.
GMAIL_PASS=tu_clave_de_aplicacion_gmail # (No es obligatorio completar este campo). Esto tiene que ser una clave de aplicacion generada por gmail. No es la contraseña de tu cuenta.

#API Sports (Datos de fútbol)
APISPORTS_KEY=tu_api_key_de_apisports # API key de api-sports.io. Necesaria para obtener datos de equipos, jugadores y fixtures.
APISPORTS_BASE_URL=https://v3.football.api-sports.io # (Opcional) URL base de la API. Por defecto usa https://v3.football.api-sports.io
APISPORTS_REQ_PER_MIN=9 # (Opcional) Límite de requests por minuto. Por defecto 9.

#Groq AI (Cálculo de precios de jugadores)
GROQ_API_KEY=tu_api_key_de_groq # API key de Groq. Necesaria para el cálculo de precios de jugadores con IA.